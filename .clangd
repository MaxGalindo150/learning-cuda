# .clangd — configuración para que clangd entienda CUDA
CompileFlags:
  Add:
    - -xcuda
    - --cuda-gpu-arch=sm_86
    - --cuda-path=/usr/local/cuda
    - -I/usr/local/cuda/include
    - -std=c++17
  Remove:
    - -forward-unknown-to-host-compiler
    - --generate-code*
    - -rdc=*
    - -Xcompiler*
    - -Xcudafe*
    - -Xptxas*
    - -arch=*

Diagnostics:
  Suppress:
    - drv_unknown_argument
    - drv_unknown_argument_with_suggestion
